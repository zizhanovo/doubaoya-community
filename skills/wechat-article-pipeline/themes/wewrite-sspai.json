{
  "meta": {
    "name": "少数派",
    "source": "https://github.com/oaker-io/wewrite (MIT) — theme \"sspai\"",
    "notes": "少数派风格：暖白底红色点缀，清爽文艺，适合数码生活和效率工具内容 Ported from oaker-io/wewrite by import-theme.mjs (wewrite-yaml). MIT License, Copyright (c) 2026 OpenClaw. See themes/LICENSE-wewrite and themes/CREDITS.md."
  },
  "palette": {
    "text": "#333333",
    "heading": "#1a1a1a",
    "accent": "#c7372f",
    "accent2": "#d4524b",
    "muted": "#888888",
    "bgSoft": "#fdf5f4",
    "border": "#c7372f",
    "link": "#c7372f",
    "codeBg": "#f5f2ed",
    "codeColor": "#c7372f",
    "pageBg": "#fafaf7"
  },
  "page": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
    "fontSize": "16px",
    "lineHeight": "1.85",
    "color": "{{text}}"
  },
  "elements": {
    "h1": {
      "style": "font-size:26px;font-weight:700;color:{{heading}};margin:36px 0 18px 0;text-align:center;line-height:1.4;"
    },
    "h2": {
      "style": "font-size:21px;font-weight:700;color:{{accent}};margin:30px 0 14px 0;padding-bottom:8px;border-bottom:2px solid {{accent}};line-height:1.4;"
    },
    "h3": {
      "style": "font-size:18px;font-weight:600;color:{{text}};margin:24px 0 12px 0;padding-left:10px;border-left:3px solid {{accent}};line-height:1.4;"
    },
    "h4": {
      "style": "font-size:16px;font-weight:600;color:{{text}};margin:20px 0 10px 0;line-height:1.4;"
    },
    "p": {
      "style": "font-size:16px;line-height:1.85;color:{{text}};margin:14px 0;"
    },
    "strong": {
      "style": "font-weight:700;color:{{accent}};"
    },
    "em": {
      "style": "font-style:italic;color:#666666;"
    },
    "code": {
      "style": "font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;font-size:14px;background:{{codeBg}};color:{{accent}};padding:2px 6px;border-radius:4px;"
    },
    "blockquote": {
      "style": "border-left:4px solid {{accent}};background:{{bgSoft}};margin:16px 0;padding:12px 16px;border-radius:0 6px 6px 0;color:#555555;"
    },
    "ul": {
      "style": "padding-left:24px;margin:14px 0;"
    },
    "ol": {
      "style": "padding-left:24px;margin:14px 0;"
    },
    "li": {
      "style": "font-size:16px;line-height:1.85;color:{{text}};margin:6px 0;"
    },
    "img": {
      "style": "max-width:100%;height:auto;display:block;margin:24px auto;border-radius:6px;"
    },
    "pre": {
      "style": "background:{{codeBg}};color:{{text}};padding:16px;border-radius:6px;overflow-x:auto;margin:16px 0;line-height:1.6;border:1px solid #e8e4dc;font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;white-space:pre-wrap;word-break:break-all;"
    },
    "a": {
      "style": "color:{{accent}};text-decoration:none;font-weight:500;"
    },
    "hr": {
      "html": "<section style=\"border:none;border-top:1px solid #e8e4dc;margin:28px 0;\"></section>"
    }
  },
  "decorations": {
    "articleWrap": {
      "before": "<section style=\"background:{{pageBg}};padding:24px 20px;\">",
      "after": "</section>"
    }
  }
}
