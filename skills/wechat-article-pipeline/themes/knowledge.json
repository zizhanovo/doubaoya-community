{
  "meta": {
    "name": "知识博主",
    "source": "handcrafted",
    "notes": "Popular readable 公众号 style: h2 as a soft-tinted colored block with a thick left accent bar (rounded), comfortable 16px/1.75 body, a callout blockquote (tinted bg + left accent border), rounded images with a soft shadow and a centered caption, and a colored dot divider. Friendly, high-contrast, mobile-first. One teal accent, brand-neutral."
  },
  "palette": {
    "text": "#2c2c2c",
    "heading": "#181818",
    "accent": "#16a37a",
    "accent2": "#0f7d5c",
    "muted": "#8a8f99",
    "bgSoft": "#eaf7f1",
    "border": "#e6e8eb",
    "link": "#0f7d5c"
  },
  "page": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif",
    "fontSize": "16px",
    "lineHeight": "1.75",
    "color": "{{text}}"
  },
  "elements": {
    "h1": {
      "style": "font-size:24px;font-weight:800;color:{{heading}};line-height:1.4;margin:8px 0 20px;"
    },
    "h2": {
      "style": "font-size:19px;font-weight:800;color:{{heading}};line-height:1.5;margin:30px 0 16px;padding:9px 14px;background:{{bgSoft}};border-left:5px solid {{accent}};border-radius:6px;"
    },
    "h3": {
      "style": "font-size:17px;font-weight:700;color:{{accent2}};line-height:1.5;margin:24px 0 12px;padding-left:10px;border-left:3px solid {{accent}};"
    },
    "h4": {
      "style": "font-size:16px;font-weight:700;color:{{heading}};line-height:1.6;margin:20px 0 10px;"
    },
    "p": {
      "style": "margin:0 0 16px;font-size:16px;line-height:1.75;color:{{text}};"
    },
    "ul": {
      "style": "margin:0 0 16px;padding-left:22px;"
    },
    "ol": {
      "style": "margin:0 0 16px;padding-left:24px;"
    },
    "li": {
      "style": "margin:0 0 10px;line-height:1.75;color:{{text}};",
      "marker": ""
    },
    "blockquote": {
      "style": "margin:0 0 18px;padding:14px 16px;background:{{bgSoft}};border-left:4px solid {{accent}};border-radius:0 8px 8px 0;color:{{text}};font-size:15.5px;line-height:1.75;"
    },
    "img": {
      "style": "max-width:100%;display:block;margin:0 auto;border-radius:10px;box-shadow:0 6px 20px rgba(20,30,40,0.12);",
      "figureStyle": "margin:22px 0;text-align:center;",
      "captionStyle": "font-size:13px;color:{{muted}};margin-top:10px;line-height:1.6;"
    },
    "hr": {
      "html": "<section style='text-align:center;margin:30px 0;color:{{accent}};font-size:14px;letter-spacing:0.55em;line-height:1;'>&bull;&bull;&bull;</section>"
    },
    "strong": {
      "style": "font-weight:700;color:{{accent2}};"
    },
    "em": {
      "style": "font-style:italic;color:{{text}};"
    },
    "del": {
      "style": "text-decoration:line-through;color:{{muted}};"
    },
    "a": {
      "style": "color:{{link}};text-decoration:underline;text-underline-offset:2px;font-weight:600;word-break:break-all;"
    },
    "code": {
      "style": "padding:2px 6px;background:{{bgSoft}};border-radius:4px;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:14px;color:{{accent2}};"
    },
    "pre": {
      "style": "margin:0 0 18px;padding:16px 18px;background:#f6f8fa;border:1px solid {{border}};border-radius:10px;overflow-x:auto;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:13.5px;line-height:1.7;color:{{text}};white-space:pre-wrap;word-break:break-all;"
    }
  },
  "decorations": {
    "articleWrap": {
      "before": "<section style='background:#ffffff;padding:22px 18px 14px;'>",
      "after": "</section>"
    },
    "sectionDivider": "<section style='text-align:center;margin:30px 0;color:{{accent}};font-size:14px;letter-spacing:0.55em;line-height:1;'>&bull;&bull;&bull;</section>"
  }
}
