{
  "meta": {
    "name": "极简金",
    "source": "https://github.com/oaker-io/wewrite (MIT) — theme \"minimal-gold\"",
    "notes": "极简金色风格：白底金色细线点缀，奢华但克制，适合高端品牌和精品内容 Ported from oaker-io/wewrite by import-theme.mjs (wewrite-yaml). MIT License, Copyright (c) 2026 OpenClaw. See themes/LICENSE-wewrite and themes/CREDITS.md."
  },
  "palette": {
    "text": "#2a2a2a",
    "heading": "#2a2a2a",
    "accent": "#b8860b",
    "accent2": "#d4a843",
    "muted": "#6b6b6b",
    "bgSoft": "#fdfbf5",
    "border": "#b8860b",
    "link": "#b8860b",
    "codeBg": "#faf8f3",
    "codeColor": "#8b6914"
  },
  "page": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
    "fontSize": "16px",
    "lineHeight": "1.8",
    "color": "{{text}}",
    "letterSpacing": "0.01em"
  },
  "elements": {
    "h1": {
      "style": "font-size:26px;font-weight:600;color:{{text}};margin:36px 0 18px 0;text-align:center;padding-bottom:14px;border-bottom:1px solid {{accent}};line-height:1.4;letter-spacing:0.05em;"
    },
    "h2": {
      "style": "font-size:21px;font-weight:600;color:{{text}};margin:30px 0 14px 0;padding-bottom:8px;border-bottom:1px solid #d4c59a;line-height:1.4;"
    },
    "h3": {
      "style": "font-size:18px;font-weight:600;color:{{accent}};margin:24px 0 12px 0;line-height:1.4;"
    },
    "h4": {
      "style": "font-size:16px;font-weight:600;color:{{text}};margin:20px 0 10px 0;line-height:1.4;"
    },
    "p": {
      "style": "font-size:16px;line-height:1.8;color:{{text}};margin:12px 0;"
    },
    "strong": {
      "style": "font-weight:700;color:{{accent}};"
    },
    "em": {
      "style": "font-style:italic;color:{{muted}};"
    },
    "code": {
      "style": "font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;font-size:14px;background:{{codeBg}};color:{{codeColor}};padding:2px 6px;border-radius:4px;"
    },
    "blockquote": {
      "style": "border-left:2px solid {{accent}};background:{{bgSoft}};margin:16px 0;padding:12px 16px;border-radius:0 4px 4px 0;color:{{muted}};"
    },
    "ul": {
      "style": "padding-left:24px;margin:12px 0;"
    },
    "ol": {
      "style": "padding-left:24px;margin:12px 0;"
    },
    "li": {
      "style": "font-size:16px;line-height:1.8;color:{{text}};margin:6px 0;"
    },
    "img": {
      "style": "max-width:100%;height:auto;display:block;margin:24px auto;border-radius:4px;"
    },
    "pre": {
      "style": "background:{{codeBg}};color:{{text}};padding:16px;border-radius:4px;overflow-x:auto;margin:16px 0;line-height:1.6;border:1px solid #e8e0c8;font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;white-space:pre-wrap;word-break:break-all;"
    },
    "a": {
      "style": "color:{{accent}};text-decoration:none;font-weight:500;"
    },
    "hr": {
      "html": "<section style=\"border:none;border-top:1px solid #d4c59a;width:40%;margin:28px auto;\"></section>"
    }
  }
}
