{
  "meta": {
    "name": "本鸭·知识清爽",
    "source": "handcrafted",
    "notes": "Default theme for doubaoya. Premium modern 公众号 look on the 本鸭 brand green — WeChat-editor-safe: NO whole-article card wrapper, and ALL heading decorations live as inline style ON the heading element itself (not empty sibling <section>/<span> boxes, which the 公众号 editor strips). h1 = bold heading + green bottom rule; h2 = green left accent bar + hairline underline (border-left/border-bottom on the h2); h3 = green left bar; blockquote is a rounded green callout card; hr is a short centered green rule (border on a section, editor-stable); images are rounded with a soft shadow + centered caption; bold text carries a subtle green highlight pill. One 本鸭 teal-green accent, high-contrast, mobile-first. Uses only inline-style templates + hr.html + img figure/caption — no script/style/class/src, no empty decorative elements, passes validate-theme."
  },
  "palette": {
    "text": "#2b2f36",
    "heading": "#14181d",
    "accent": "#16a37a",
    "accent2": "#0e7d5f",
    "muted": "#97a0ab",
    "bgSoft": "#e9f7f1",
    "border": "#e6ebe8",
    "link": "#0e7d5f"
  },
  "page": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif",
    "fontSize": "16px",
    "lineHeight": "1.8",
    "letterSpacing": "0.01em",
    "color": "{{text}}"
  },
  "elements": {
    "h1": {
      "style": "font-size:25px;font-weight:800;color:{{heading}};line-height:1.4;letter-spacing:0.01em;margin:6px 0 22px;padding-bottom:12px;border-bottom:3px solid {{accent}};"
    },
    "h2": {
      "style": "font-size:20px;font-weight:800;color:{{heading}};line-height:1.5;letter-spacing:0.01em;margin:32px 0 16px;padding:0 0 8px 11px;border-left:4px solid {{accent}};border-bottom:1px solid {{border}};"
    },
    "h3": {
      "style": "font-size:17px;font-weight:700;color:{{accent2}};line-height:1.55;margin:24px 0 12px;padding-left:11px;border-left:3px solid {{accent}};"
    },
    "h4": {
      "style": "font-size:16px;font-weight:700;color:{{heading}};line-height:1.6;margin:20px 0 10px;"
    },
    "p": {
      "style": "margin:0 0 16px;font-size:16px;line-height:1.8;color:{{text}};"
    },
    "ul": {
      "style": "margin:0 0 16px;padding-left:22px;"
    },
    "ol": {
      "style": "margin:0 0 16px;padding-left:24px;"
    },
    "li": {
      "style": "margin:0 0 10px;line-height:1.8;color:{{text}};",
      "marker": ""
    },
    "blockquote": {
      "style": "margin:20px 0;padding:15px 18px;background:{{bgSoft}};border:1px solid rgba(22,163,122,0.16);border-left:4px solid {{accent}};border-radius:10px;color:{{text}};font-size:15.5px;line-height:1.8;"
    },
    "img": {
      "style": "max-width:100%;display:block;margin:0 auto;border-radius:12px;box-shadow:0 8px 24px rgba(18,58,44,0.14);",
      "figureStyle": "margin:24px 0;text-align:center;",
      "captionStyle": "font-size:13px;color:{{muted}};margin-top:11px;line-height:1.6;"
    },
    "hr": {
      "html": "<section style='width:40px;border-top:2px solid {{accent}};margin:34px auto;'></section>"
    },
    "strong": {
      "style": "font-weight:700;color:{{accent2}};background:{{bgSoft}};border-radius:4px;padding:0 4px;"
    },
    "em": {
      "style": "font-style:italic;color:{{accent2}};"
    },
    "del": {
      "style": "text-decoration:line-through;color:{{muted}};"
    },
    "a": {
      "style": "color:{{link}};text-decoration:underline;text-underline-offset:2px;font-weight:600;word-break:break-all;"
    },
    "code": {
      "style": "padding:2px 6px;background:{{bgSoft}};border-radius:4px;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:14px;color:{{accent2}};"
    },
    "pre": {
      "style": "margin:0 0 18px;padding:16px 18px;background:#f6f8fa;border:1px solid {{border}};border-radius:10px;overflow-x:auto;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:13.5px;line-height:1.7;color:{{text}};white-space:pre-wrap;word-break:break-all;"
    }
  },
  "decorations": {
    "articleWrap": {
      "before": "",
      "after": ""
    },
    "sectionDivider": "<section style='width:40px;border-top:2px solid {{accent}};margin:34px auto;'></section>"
  }
}
