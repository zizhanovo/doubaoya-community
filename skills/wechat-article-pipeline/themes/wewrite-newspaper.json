{
  "meta": {
    "name": "报刊",
    "source": "https://github.com/oaker-io/wewrite (MIT) — theme \"newspaper\"",
    "notes": "经典报纸风格：米黄底深棕文字，衬线字体质感，适合深度报道和评论 Ported from oaker-io/wewrite by import-theme.mjs (wewrite-yaml). MIT License, Copyright (c) 2026 OpenClaw. See themes/LICENSE-wewrite and themes/CREDITS.md."
  },
  "palette": {
    "text": "#2c2416",
    "heading": "#2c2416",
    "accent": "#8b4513",
    "accent2": "#a0522d",
    "muted": "#5c4a3a",
    "bgSoft": "#f0eade",
    "border": "#8b4513",
    "link": "#8b4513",
    "codeBg": "#ede7db",
    "codeColor": "#8b4513",
    "pageBg": "#f5f0e8"
  },
  "page": {
    "fontFamily": "Georgia, 'Songti SC', 'SimSun', 'Noto Serif SC', serif",
    "fontSize": "16px",
    "lineHeight": "1.9",
    "color": "{{text}}"
  },
  "elements": {
    "h1": {
      "style": "font-size:28px;font-weight:700;color:{{text}};margin:36px 0 16px 0;text-align:center;padding-bottom:12px;border-bottom:3px double {{accent}};line-height:1.3;letter-spacing:0.03em;"
    },
    "h2": {
      "style": "font-size:22px;font-weight:700;color:{{text}};margin:30px 0 14px 0;padding-bottom:8px;border-bottom:1px solid {{accent}};line-height:1.4;"
    },
    "h3": {
      "style": "font-size:16px;font-weight:700;color:{{muted}};margin:24px 0 12px 0;line-height:1.4;text-transform:uppercase;letter-spacing:0.05em;"
    },
    "h4": {
      "style": "font-size:16px;font-weight:700;color:{{muted}};margin:20px 0 10px 0;line-height:1.4;"
    },
    "p": {
      "style": "font-size:16px;line-height:1.9;color:{{text}};margin:14px 0;text-align:justify;"
    },
    "strong": {
      "style": "font-weight:700;color:{{text}};"
    },
    "em": {
      "style": "font-style:italic;color:{{muted}};"
    },
    "code": {
      "style": "font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;font-size:14px;background:{{codeBg}};color:{{accent}};padding:2px 6px;border-radius:2px;"
    },
    "blockquote": {
      "style": "border-left:3px solid {{accent}};background:{{bgSoft}};margin:16px 0;padding:12px 16px;border-radius:0 2px 2px 0;color:{{muted}};font-style:italic;"
    },
    "ul": {
      "style": "padding-left:24px;margin:14px 0;"
    },
    "ol": {
      "style": "padding-left:24px;margin:14px 0;"
    },
    "li": {
      "style": "font-size:16px;line-height:1.9;color:{{text}};margin:6px 0;"
    },
    "img": {
      "style": "max-width:100%;height:auto;display:block;margin:24px auto;border-radius:2px;border:1px solid #d4cbb8;"
    },
    "pre": {
      "style": "background:{{codeBg}};color:{{text}};padding:16px;border-radius:2px;overflow-x:auto;margin:16px 0;line-height:1.6;border:1px solid #d4cbb8;font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;white-space:pre-wrap;word-break:break-all;"
    },
    "a": {
      "style": "color:{{accent}};text-decoration:underline;font-weight:500;"
    },
    "hr": {
      "html": "<section style=\"border:none;border-top:1px solid #d4cbb8;width:60%;margin:28px auto;\"></section>"
    }
  },
  "decorations": {
    "articleWrap": {
      "before": "<section style=\"background:{{pageBg}};padding:24px 20px;\">",
      "after": "</section>"
    }
  }
}
