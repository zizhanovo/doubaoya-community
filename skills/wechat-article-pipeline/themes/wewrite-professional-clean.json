{
  "meta": {
    "name": "专业净",
    "source": "https://github.com/oaker-io/wewrite (MIT) — theme \"professional-clean\"",
    "notes": "干净专业的企业公众号风格，适合大多数商业内容 Ported from oaker-io/wewrite by import-theme.mjs (wewrite-yaml). MIT License, Copyright (c) 2026 OpenClaw. See themes/LICENSE-wewrite and themes/CREDITS.md."
  },
  "palette": {
    "text": "#333333",
    "heading": "#1a1a1a",
    "accent": "#2563eb",
    "accent2": "#3b82f6",
    "muted": "#666666",
    "bgSoft": "#eff6ff",
    "border": "#2563eb",
    "link": "#2563eb",
    "codeBg": "#1e293b",
    "codeColor": "#e2e8f0"
  },
  "page": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
    "fontSize": "16px",
    "lineHeight": "1.8",
    "color": "{{text}}"
  },
  "elements": {
    "h1": {
      "style": "font-size:26px;font-weight:700;color:{{heading}};margin:32px 0 16px 0;padding-bottom:12px;border-bottom:2px solid {{accent}};line-height:1.4;"
    },
    "h2": {
      "style": "font-size:22px;font-weight:700;color:{{heading}};margin:28px 0 14px 0;padding:8px 0 8px 12px;border-left:4px solid {{accent}};border-bottom:1px solid #e5e7eb;line-height:1.4;"
    },
    "h3": {
      "style": "font-size:18px;font-weight:600;color:{{text}};margin:24px 0 12px 0;line-height:1.4;"
    },
    "h4": {
      "style": "font-size:16px;font-weight:600;color:{{text}};margin:20px 0 10px 0;line-height:1.4;"
    },
    "p": {
      "style": "font-size:16px;line-height:1.8;color:{{text}};margin:12px 0;"
    },
    "strong": {
      "style": "font-weight:700;color:{{heading}};"
    },
    "em": {
      "style": "font-style:italic;color:{{text}};"
    },
    "code": {
      "style": "font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;font-size:14px;background:#f1f5f9;color:#d946ef;padding:2px 6px;border-radius:4px;"
    },
    "blockquote": {
      "style": "border-left:4px solid {{accent}};background:{{bgSoft}};margin:16px 0;padding:12px 16px;border-radius:0 8px 8px 0;color:{{text}};"
    },
    "ul": {
      "style": "padding-left:24px;margin:12px 0;"
    },
    "ol": {
      "style": "padding-left:24px;margin:12px 0;"
    },
    "li": {
      "style": "font-size:16px;line-height:1.8;color:{{text}};margin:6px 0;"
    },
    "img": {
      "style": "max-width:100%;height:auto;display:block;margin:24px auto;border-radius:8px;"
    },
    "pre": {
      "style": "background:{{codeBg}};color:{{codeColor}};padding:16px;border-radius:8px;overflow-x:auto;margin:16px 0;line-height:1.6;font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;white-space:pre-wrap;word-break:break-all;"
    },
    "a": {
      "style": "color:{{accent}};text-decoration:none;font-weight:500;"
    },
    "hr": {
      "html": "<section style=\"border:none;border-top:1px solid #e5e7eb;margin:24px 0;\"></section>"
    }
  }
}
