{
  "meta": {
    "name": "水墨",
    "source": "https://github.com/oaker-io/wewrite (MIT) — theme \"ink\"",
    "notes": "水墨中国风：宣纸底墨色文字，中文衬线字体，留白疏朗，适合文化和人文内容 Ported from oaker-io/wewrite by import-theme.mjs (wewrite-yaml). MIT License, Copyright (c) 2026 OpenClaw. See themes/LICENSE-wewrite and themes/CREDITS.md."
  },
  "palette": {
    "text": "#1a1a1a",
    "heading": "#1a1a1a",
    "accent": "#4a4a4a",
    "accent2": "#6b6b6b",
    "muted": "#666666",
    "bgSoft": "#f4f0e8",
    "border": "#999999",
    "link": "#555555",
    "codeBg": "#f0ebe3",
    "codeColor": "#555555",
    "pageBg": "#f8f5f0"
  },
  "page": {
    "fontFamily": "'Songti SC', 'SimSun', 'Noto Serif SC', Georgia, serif",
    "fontSize": "16px",
    "lineHeight": "2",
    "color": "{{text}}"
  },
  "elements": {
    "h1": {
      "style": "font-size:28px;font-weight:700;color:{{text}};margin:48px 0 24px 0;text-align:center;line-height:1.4;letter-spacing:0.1em;"
    },
    "h2": {
      "style": "font-size:22px;font-weight:700;color:{{text}};margin:40px 0 16px 0;text-align:center;padding-bottom:12px;line-height:1.4;letter-spacing:0.05em;"
    },
    "h3": {
      "style": "font-size:18px;font-weight:600;color:#333333;margin:32px 0 14px 0;line-height:1.4;letter-spacing:0.03em;"
    },
    "h4": {
      "style": "font-size:16px;font-weight:600;color:#333333;margin:24px 0 12px 0;line-height:1.4;"
    },
    "p": {
      "style": "font-size:16px;line-height:2;color:{{text}};margin:16px 0;text-indent:2em;"
    },
    "strong": {
      "style": "font-weight:700;color:{{text}};"
    },
    "em": {
      "style": "font-style:italic;color:{{muted}};"
    },
    "code": {
      "style": "font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;font-size:14px;background:{{codeBg}};color:{{codeColor}};padding:2px 6px;border-radius:2px;"
    },
    "blockquote": {
      "style": "border-left:3px solid {{border}};background:{{bgSoft}};margin:20px 0;padding:14px 18px;border-radius:0 2px 2px 0;color:{{codeColor}};font-style:italic;"
    },
    "ul": {
      "style": "padding-left:24px;margin:16px 0;"
    },
    "ol": {
      "style": "padding-left:24px;margin:16px 0;"
    },
    "li": {
      "style": "font-size:16px;line-height:2;color:{{text}};margin:8px 0;"
    },
    "img": {
      "style": "max-width:100%;height:auto;display:block;margin:32px auto;border-radius:2px;"
    },
    "pre": {
      "style": "background:{{codeBg}};color:{{text}};padding:16px;border-radius:2px;overflow-x:auto;margin:20px 0;line-height:1.6;border:1px solid #ddd5c8;font-family:'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace;white-space:pre-wrap;word-break:break-all;"
    },
    "a": {
      "style": "color:{{codeColor}};text-decoration:underline;"
    },
    "hr": {
      "html": "<section style=\"border:none;border-bottom:1px solid #ccc5b8;height:20px;margin:36px 0;\"></section>"
    }
  },
  "decorations": {
    "articleWrap": {
      "before": "<section style=\"background:{{pageBg}};padding:24px 20px;\">",
      "after": "</section>"
    }
  }
}
